# =============================================
# BPKB IPB Client — Environment Variables (Vite)
# =============================================
# Salin file ini menjadi .env dan isi sesuai konfigurasi Anda.
# Semua variabel HARUS diawali dengan VITE_ agar terbaca oleh Vite.

# URL backend API (tanpa trailing slash)
# Development : http://localhost:5000/api
# Production  : https://your-backend.onrender.com/api
VITE_API_URL=http://localhost:5000/api
