# =============================================
# BPKB IPB Server — Environment Variables
# =============================================
# Salin file ini menjadi .env dan isi sesuai konfigurasi Anda.

# ---- Server ----
PORT=5000
NODE_ENV=development
# URL frontend (untuk CORS & CSP)
CLIENT_URL=http://localhost:5173

# ---- Database (PostgreSQL) ----
DIRECT_URL="postgresql://postgres.zavxfhzujiyzswjjrdme:Abc123@aws-1-ap-southeast-2.pooler.supabase.com:5432/postgres"

DATABASE_URL=postgresql://postgres:password@localhost:5432/bpkb_ipb

# ---- Authentication (JWT) ----
JWT_SECRET=ganti_dengan_string_acak_yang_sangat_panjang_dan_rahasia

# ---- Encryption (AES-256) ----
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=ganti_dengan_64_karakter_hex

# ---- SMTP (Email OTP) ----
# Contoh menggunakan Gmail App Password:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_USER=email@gmail.com
#   SMTP_PASS=xxxx xxxx xxxx xxxx  (App Password, bukan password biasa)
#
# Contoh menggunakan Mailtrap (testing):
#   SMTP_HOST=sandbox.smtp.mailtrap.io
#   SMTP_PORT=2525
#   SMTP_USER=your_mailtrap_user
#   SMTP_PASS=your_mailtrap_pass
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="BPKB IPB" <noreply@bpkb-ipb.ac.id>
